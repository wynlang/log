test "default level" {
    // Test log level filtering
    var level = 0
    assert_eq(level, 0)
}

test "set level" {
    // Test log level filtering
    var level = 0
    level = 2
    assert_eq(level, 2)
}

test "info prefix" {
    // Test log level filtering
    var level = 0
    level = 2
    // Test log output format
    var msg = "[INFO]  server started"
    assert(msg.starts_with("[INFO]"))
}

test "error prefix" {
    // Test log level filtering
    var level = 0
    level = 2
    // Test log output format
    var msg = "[INFO]  server started"
    var err = "[ERROR] connection failed"
    assert(err.starts_with("[ERROR]"))
}
